    {
      "parameters": {
        "jsCode": "const hashItems = $input.all();\nconst splitItems = $('Split Out').all();\nconst results = [];\n\nfor (let i = 0; i < hashItems.length; i++) {\n  const hash = hashItems[i].json.stdout.trim();\n  const splitItem = splitItems[i].json;\n  \n  results.push({\n    json: {\n      path: splitItem.path,\n      fileName: splitItem.fileName,\n      department: splitItem.department,\n      confidentiality_level: splitItem.confidentiality_level,\n      valid_until: splitItem.valid_until,\n      document_hash: hash\n    }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
