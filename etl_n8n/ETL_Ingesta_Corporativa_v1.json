    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "f05a622f-facf-471e-ae78-305e425452d9",
              "name": "listaArchivos",
              "value": "={{ ($json.stdout || '').split('\\n').filter(n => n.trim() !== '').map(n => {\n  const fileName = n.trim();\n  const path = '/data/documents/' + fileName;\n  \n  let department = 'Administración';\n  if (fileName.includes('_RRHH_')) department = 'RRHH';\n  \n  let confidentiality_level = 'Público';\n  const numMatch = fileName.match(/_(\\d{2})_/);\n  const num = numMatch ? parseInt(numMatch[1]) : 99;\n  const esExtenso = fileName.includes('extensos');\n  \n  if (esExtenso) {\n    confidentiality_level = 'Confidencial';\n  } else if (department === 'Administración') {\n    if (num <= 4) confidentiality_level = 'Público';\n    else if (num <= 8) confidentiality_level = 'Interno';\n    else confidentiality_level = 'Confidencial';\n  } else {\n    if (num <= 3) confidentiality_level = 'Público';\n    else if (num <= 6) confidentiality_level = 'Interno';\n    else confidentiality_level = 'Confidencial';\n  }\n  \n  let valid_until = null;\n  const expMatch = fileName.match(/__EXP(\\d{4})(\\d{2})(\\d{2})/);\n  if (expMatch) {\n    valid_until = `${expMatch[1]}-${expMatch[2]}-${expMatch[3]}T23:59:59Z`;\n  }\n  \n  return { path, fileName, department, confidentiality_level, valid_until };\n}) }}",
              "type": "array"
            }
          ]
        },
        "options": {}
      },
