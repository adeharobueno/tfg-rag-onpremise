    {
      "parameters": {
        "jsCode": "const httpItems = $input.all();\nconst codeItems = $('Code in JavaScript').all();\nconst results = [];\n\nfor (let i = 0; i < httpItems.length; i++) {\n  const exists = httpItems[i].json.exists;\n  const codeItem = codeItems[i].json;\n  \n  results.push({\n    json: {\n      exists: exists,\n      path: codeItem.path,\n      fileName: codeItem.fileName,\n      department: codeItem.department,\n      confidentiality_level: codeItem.confidentiality_level,\n      valid_until: codeItem.valid_until,\n      document_hash: codeItem.document_hash\n    }\n  });\n}\n\nreturn results;"
      },
