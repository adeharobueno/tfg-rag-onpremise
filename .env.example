# ============================================================
# TFG RAG On-Premise โ Variables de Entorno
# Copia este fichero como .env y modifica los valores
# cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=CambiarPorContraseรฑaSegura2026
POSTGRES_DB=tfg_rag_db

# --- Rol de servicio api_gateway (conexiรณn con RLS) ---
API_GATEWAY_USER=api_gateway
API_GATEWAY_PASSWORD=CambiarPorOtraContraseรฑaSegura2026?

# --- JWT ---
JWT_SECRET=CambiarPorUnSecretoLargoYAleatorio2026

# --- Ollama ---
OLLAMA_HOST=http://ollama_engine:11434
OLLAMA_NUM_PARALLEL=2

# --- n8n ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CambiarContraseรฑaN8N2026

# --- URLs de conexiรณn (construidas desde las variables anteriores) ---
# Conexiรณn con RLS (rol api_gateway, sin superuser)
DATABASE_URL=postgresql://api_gateway:CambiarPorOtraContraseรฑaSegura2026%3F@postgres_db:5432/tfg_rag_db
# Conexiรณn admin (superusuario, solo para operaciones internas)
DATABASE_URL_ADMIN=postgresql://postgres:CambiarPorContraseรฑaSegura2026@postgres_db:5432/tfg_rag_db

# --- Nota sobre caracteres especiales ---
# Si API_GATEWAY_PASSWORD contiene ? u otros caracteres especiales,
# deben escaparse con URL-encoding en DATABASE_URL:
#   ? โ %3F    @ โ %40    # โ %23    % โ %25
